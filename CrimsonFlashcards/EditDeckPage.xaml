<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CrimsonFlashcards"
             x:Class="CrimsonFlashcards.EditDeckPage"
             NavigationPage.HasNavigationBar="False"
             Title="EditDeckPage">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto, Auto"
          Padding="20"
          RowSpacing="15">

        <!-- Шапка -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
            <Button x:Name="BackButton"
                    ImageSource="cross.png"
                    HorizontalOptions="Start"
                    Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   Text="{Binding PageTitle}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource CrimsonAccent}"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- Поля метаданных -->
        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Entry x:Name="ThemeEntry"
                   Placeholder="Тема"
                   Text="{Binding Theme}"
                   BackgroundColor="{StaticResource SurfaceDark}"
                   TextColor="White"
                   PlaceholderColor="{StaticResource TextSecondary}"
                   FontSize="16"/>
            <Editor x:Name="DescriptionEditor"
                    Placeholder="Описание (необязательно)"
                    Text="{Binding Description}"
                    BackgroundColor="{StaticResource SurfaceDark}"
                    TextColor="White"
                    PlaceholderColor="{StaticResource TextSecondary}"
                    HeightRequest="80"
                    AutoSize="TextChanges"/>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <Entry Grid.Column="0"
                       Placeholder="Язык лицевой стороны"
                       Text="{Binding FaceLang}"
                       BackgroundColor="{StaticResource SurfaceDark}"
                       TextColor="White"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       FontSize="16"/>
                <Entry Grid.Column="1"
                       Placeholder="Язык обратной стороны"
                       Text="{Binding BackLang}"
                       BackgroundColor="{StaticResource SurfaceDark}"
                       TextColor="White"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       FontSize="16"/>
            </Grid>
        </VerticalStackLayout>

        <Label Grid.Row="2"
               Text="Карточки"
               HorizontalOptions="Center"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="{StaticResource CrimsonAccent}"/>

        <CollectionView Grid.Row="3"
                        x:Name="CardsCollection"
                        ItemsSource="{Binding Cards}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, *, Auto"
                          ColumnSpacing="10"
                          Margin="0,5">
                        <Entry Grid.Column="0"
                               Placeholder="{Binding FacePlaceholder}"
                               Text="{Binding Face}"
                               BackgroundColor="{StaticResource SurfaceDark}"
                               TextColor="White"
                               PlaceholderColor="{StaticResource TextSecondary}"/>
                        <Entry Grid.Column="1"
                               Placeholder="{Binding BackPlaceholder}"
                               Text="{Binding Back}"
                               BackgroundColor="{StaticResource SurfaceDark}"
                               TextColor="White"
                               PlaceholderColor="{StaticResource TextSecondary}"/>
                        <Button Grid.Column="2"
                                ImageSource="cross.png"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:EditDeckPage}}, Path=RemoveCommand}"
                                CommandParameter="{Binding .}"
                                />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="4"
                Text="Добавить карточку"
                Command="{Binding AddCommand}"
                BackgroundColor="{StaticResource SurfaceDark}"
                TextColor="White"
                CornerRadius="12"
                FontSize="16"
                Padding="10"/>

        <Button Grid.Row="5"
                Text="Сохранить колоду"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource CrimsonAccent}"
                TextColor="White"
                CornerRadius="12"
                FontSize="16"
                Padding="10"/>
    </Grid>
</ContentPage>